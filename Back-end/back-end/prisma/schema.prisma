generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserRoles {
  id        Int    @id @default(autoincrement())
  role_name String @unique
  users     Users[]
}

model Users {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role_id    Int
  role       UserRoles @relation(fields: [role_id], references: [id])
  created_at DateTime @default(now())
  profile    CustomerProfiles?
  notifications Notifications[]
  reviews    ProductReviews[]
  orderReturns OrderReturns[]

  @@index([email])
  deleted_at DateTime?
}

model CustomerProfiles {
  id              String @id @default(uuid())
  user_id         String @unique
  user            Users  @relation(fields: [user_id], references: [id])
  full_name       String
  phone           String
  default_address String
  orders          Orders[]
}

model Categories {
  id        Int    @id @default(autoincrement())
  category_name String @unique
  products  Products[]
}

model Products {
  id           String @id @default(uuid())
  name         String
  description  String
  price        Decimal
  image_url    String
  category_id  Int
  category     Categories @relation(fields: [category_id], references: [id])
  stock_quantity Int
  is_available Boolean @default(true)
  orderItems   OrderItems[]
  reviews      ProductReviews[]  // 🟢 NEW: Relation to reviews
  deleted_at   DateTime?

  @@index([category_id]) 
  @@index([name])
}

model OrderStatuses {
  id          Int    @id @default(autoincrement())
  status_name String
  orders      Orders[]
}

model Orders {
  id            String @id @default(uuid())
  customer_id   String?
  customer      CustomerProfiles? @relation(fields: [customer_id], references: [id])
  customer_email      String?  
  customer_phone      String?  
  cancellation_reason String? 
  total_price   Decimal
  order_type    String
  scheduled_for DateTime
  status_id     Int
  status        OrderStatuses @relation(fields: [status_id], references: [id])
  created_at    DateTime @default(now())
  deleted_at    DateTime?
  orderItems    OrderItems[]
  payment       Payments?
  returns       OrderReturns[]
  statusLogs    OrderStatusLogs[]

  @@index([customer_id]) 
  @@index([status_id])   
  @@index([created_at])
}

model OrderReturns {
  id         String   @id @default(uuid())
  order_id   String
  order      Orders   @relation(fields: [order_id], references: [id])
  user_id    String
  user       Users    @relation(fields: [user_id], references: [id])
  reason     String   @db.Text
  status     String   @default("Pending") // 'Pending', 'Approved', 'Rejected', 'Processed'
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model OrderStatusLogs {
  id         Int      @id @default(autoincrement())
  order_id   String
  order      Orders   @relation(fields: [order_id], references: [id])
  old_status Int
  new_status Int
  changed_at DateTime @default(now())
}

model OrderItems {
  id         String @id @default(uuid())
  order_id   String
  order      Orders @relation(fields: [order_id], references: [id])
  product_id String
  product    Products @relation(fields: [product_id], references: [id])
  quantity   Int
  subtotal   Decimal

  @@index([order_id])   
  @@index([product_id])
}

model Payments {
  id                  String @id @default(uuid())
  order_id            String @unique
  order               Orders @relation(fields: [order_id], references: [id])
  amount              Decimal
  payment_method      String
  payment_status      String
  transaction_reference String? @unique
  paid_at             DateTime?

  @@index([transaction_reference])
}

model Notifications {
  id           Int    @id @default(autoincrement())
  user_id      String
  user         Users  @relation(fields: [user_id], references: [id])
  message      String
  trigger_type String
  is_read      Boolean @default(false)
  created_at   DateTime @default(now())

  @@index([user_id, is_read])
}

model AuditLogs {
  id         Int      @id @default(autoincrement())
  user_id    String
  action     String   // e.g., "UPDATE_ORDER_STATUS"
  endpoint   String   // e.g., "/api/admin/orders/:id/status"
  timestamp  DateTime @default(now())
  details    Json?    // Optional: capture request body or changes

  @@index([timestamp])
}

// ============================================================
// 🟢 TASK 2: PRODUCT REVIEW & RATING SYSTEM
// ============================================================
model ProductReviews {
  id                   String   @id @default(uuid())
  product_id           String
  product              Products @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user_id              String
  user                 Users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rating               Int      // 1-5
  comment              String   @db.Text
  is_verified_purchase Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@unique([product_id, user_id]) // Prevent duplicate reviews
  @@index([product_id])
  @@index([user_id])
  @@index([created_at])
}